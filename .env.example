# Environment — PulseMiner Ghana Pilot
# Copy this to .env and fill in your values

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://pulseminer:pulseminer@localhost:5432/pulseminer

# ─── Cache ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Storage (S3-compatible) ─────────────────────────────────
STORAGE_BUCKET=pulseminer-raw
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# ─── AI / NLP ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
HF_API_KEY=hf_...

# ─── News APIs ───────────────────────────────────────────────
NEWS_API_KEY=...
# Ghana-specific news aggregator key (e.g. GhanaWeb, CitiNewsroom)
GHANA_NEWS_API_KEY=...

# ─── Trends ──────────────────────────────────────────────────
# Google Trends is used via pytrends (no key required by default)
TRENDS_PROVIDER_KEY=

# ─── Voice Transcription ─────────────────────────────────────
VOICE_TRANSCRIPTION_KEY=...

# ─── Services ────────────────────────────────────────────────
API_PORT=3001
PROCESSING_SERVICE_URL=http://localhost:8000
INGESTION_INTERVAL_MS=300000

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Pilot ───────────────────────────────────────────────────
PILOT_COUNTRY=GH
PILOT_LABEL=Ghana
